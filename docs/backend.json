
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "referralCode": { "type": "string" },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "MockAttempt": {
      "title": "Mock Attempt",
      "description": "Record of a student's performance in a mock test.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mockId": { "type": "string" },
        "score": { "type": "number" },
        "accuracy": { "type": "number" },
        "timeTaken": { "type": "number" },
        "answers": { "type": "object" },
        "createdAt": { "type": "number" }
      }
    },
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "Real-time rank record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "xp": { "type": "number" },
        "accuracy": { "type": "number" },
        "streak": { "type": "number" },
        "district": { "type": "string" }
      }
    },
    "Subscription": {
      "title": "Subscription",
      "description": "PASS premium access record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "plan": { "type": "string" },
        "status": { "type": "string" },
        "endDate": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and settings."
    },
    "/attempts/{attemptId}": {
      "schema": "MockAttempt",
      "description": "History of mock test attempts."
    },
    "/leaderboards/{userId}": {
      "schema": "LeaderboardEntry",
      "description": "Global and district rankings."
    },
    "/subscriptions/{userId}": {
      "schema": "Subscription",
      "description": "User premium access status."
    },
    "/mocks/{mockId}": {
      "schema": "object",
      "description": "Master list of available mocks."
    },
    "/questions/{qId}": {
      "schema": "object",
      "description": "Academic question bank."
    }
  }
}
