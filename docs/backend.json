
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "district": { "type": "string" },
        "targetExam": { "type": "string" },
        "isPro": { "type": "boolean" },
        "referralCode": { "type": "string" },
        "createdAt": { "type": "number" },
        "bookmarks": { "type": "array" }
      }
    },
    "Question": {
      "title": "Question Bank Item",
      "description": "Atomic bilingual question for the central bank.",
      "type": "object",
      "properties": {
        "question_en": { "type": "string" },
        "question_pa": { "type": "string" },
        "options_en": { "type": "array" },
        "options_pa": { "type": "array" },
        "correctAnswer": { "type": "string" },
        "explanation_en": { "type": "string" },
        "explanation_pa": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "exam": { "type": "string" },
        "pyq": { "type": "boolean" },
        "year": { "type": "number" },
        "source": { "type": "string" },
        "usageCount": { "type": "number" },
        "createdAt": { "type": "number" }
      }
    },
    "MockTest": {
      "title": "Mock Test",
      "description": "CBT Exam configuration.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "exam": { "type": "string" },
        "duration": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "negativeMarking": { "type": "number" },
        "isLive": { "type": "boolean" },
        "published": { "type": "boolean" },
        "questionIds": { "type": "array" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles and roles."
    },
    "/questions/{qId}": {
      "schema": "Question",
      "description": "Central bilingual question bank."
    },
    "/mocks/{mockId}": {
      "schema": "MockTest",
      "description": "Standardized mock tests referencing question IDs."
    },
    "/community_messages/{msgId}": {
      "schema": "CommunityMessage",
      "description": "Real-time discussion streams."
    }
  }
}
