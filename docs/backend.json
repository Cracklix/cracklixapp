{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "level": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "missionsCompleted": { "type": "number" },
        "lastActive": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "AiChat": {
      "title": "AI Chat History",
      "description": "Record of student interaction with the AI tutor.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "response": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "ocr", "voice"] },
        "createdAt": { "type": "number" }
      }
    },
    "AiRecommendation": {
      "title": "AI Recommendation",
      "description": "Personalized study advice generated by AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "weakTopics": { "type": "array", "items": { "type": "string" } },
        "strategy": { "type": "string" },
        "motivation": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Product": {
      "title": "Marketplace Product",
      "description": "A study resource for sale (PDF, Notes, etc.)",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "thumbnail": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "downloads": { "type": "number" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "createdAt": { "type": "number" }
      }
    },
    "DailyTarget": {
      "title": "Daily Target",
      "description": "Daily study and practice goals for a student.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questionsGoal": { "type": "number" },
        "questionsCompleted": { "type": "number" },
        "mockGoal": { "type": "number" },
        "mockCompleted": { "type": "number" },
        "studyMinutesGoal": { "type": "number" },
        "studyMinutesCompleted": { "type": "number" },
        "date": { "type": "string" }
      }
    },
    "MistakeEntry": {
      "title": "Mistake Entry",
      "description": "A question incorrectly answered by the student for revision.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questionId": { "type": "string" },
        "questionText": { "type": "string" },
        "correctAnswer": { "type": "string" },
        "userAnswer": { "type": "string" },
        "topic": { "type": "string" },
        "subject": { "type": "string" },
        "savedAt": { "type": "number" }
      }
    },
    "LiveTest": {
      "title": "Live Test",
      "description": "A high-stakes scheduled test competition.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "exam": { "type": "string" },
        "startTime": { "type": "number" },
        "endTime": { "type": "number" },
        "duration": { "type": "number" },
        "questions": { "type": "number" },
        "participants": { "type": "number" },
        "live": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles."
    },
    "/aiChats/{chatId}": {
      "schema": "AiChat",
      "description": "History of AI tutor sessions."
    },
    "/aiRecommendations/{userId}": {
      "schema": "AiRecommendation",
      "description": "AI-generated learning plans."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Study materials for sale."
    },
    "/dailyTargets/{userId}": {
      "schema": "DailyTarget",
      "description": "Daily goals tracking."
    },
    "/mistakeNotebook/{id}": {
      "schema": "MistakeEntry",
      "description": "Repository of wrong answers for revision."
    },
    "/liveTests/{id}": {
      "schema": "LiveTest",
      "description": "Scheduled competitions."
    }
  }
}