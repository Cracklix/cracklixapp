
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "level": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "missionsCompleted": { "type": "number" },
        "lastActive": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "LiveClass": {
      "title": "Live Class",
      "description": "A live or recorded instructional session.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "exam": { "type": "string" },
        "thumbnail": { "type": "string" },
        "description": { "type": "string" },
        "live": { "type": "boolean" },
        "meetingId": { "type": "string" },
        "scheduledAt": { "type": "number" },
        "createdAt": { "type": "number" }
      }
    },
    "ClassChat": {
      "title": "Class Chat",
      "description": "Messages sent during a live class.",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "Logs of user participation in live sessions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "classId": { "type": "string" },
        "joinedAt": { "type": "number" }
      }
    },
    "AdminRecord": {
      "title": "Admin Record",
      "description": "Permissions and status for admin accounts.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "active": { "type": "boolean" },
        "createdAt": { "type": "number" }
      }
    },
    "CMSContent": {
      "title": "CMS Content",
      "description": "Platform-wide articles and announcements.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles."
    },
    "/liveClasses/{classId}": {
      "schema": "LiveClass",
      "description": "Live session registry."
    },
    "/classChats/{id}": {
      "schema": "ClassChat",
      "description": "Class-specific chat messages."
    },
    "/attendance/{id}": {
      "schema": "Attendance",
      "description": "Session participation logs."
    },
    "/admins/{id}": {
      "schema": "AdminRecord",
      "description": "Administrative account registry."
    },
    "/cms/{id}": {
      "schema": "CMSContent",
      "description": "Content management repository."
    },
    "/auditLogs/{id}": {
      "schema": "AuditLog",
      "description": "Admin activity history."
    },
    "/featureFlags/{id}": {
      "schema": "FeatureFlag",
      "description": "Platform feature controls."
    },
    "/notifications/{id}": {
      "schema": "Notification",
      "description": "User-specific alerts."
    },
    "/liveActivity/{id}": {
      "schema": "LiveActivity",
      "description": "Global activity feed."
    },
    "/currentAffairs/{id}": {
      "schema": "CurrentAffair",
      "description": "Article feed."
    },
    "/mocks/{id}": {
      "schema": "MockTest",
      "description": "Exam simulations."
    },
    "/attempts/{id}": {
      "schema": "Attempt",
      "description": "Historical performance logs."
    },
    "/payments/{id}": {
      "schema": "Payment",
      "description": "Financial records."
    }
  }
}
