
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "district": { "type": "string" },
        "targetExam": { "type": "string" },
        "isPro": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "bookmarks": { "type": "array" }
      }
    },
    "CommunityMessage": {
      "title": "Community Message",
      "description": "Messages within exam-specific chat channels.",
      "type": "object",
      "properties": {
        "channelId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "fileUrl": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "MockTest": {
      "title": "Mock Test",
      "description": "Academic mock test configuration.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "exam": { "type": "string" },
        "duration": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "negativeMarking": { "type": "number" },
        "isLive": { "type": "boolean" },
        "published": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and performance data."
    },
    "/questions/{qId}": {
      "schema": "object",
      "description": "Global question bank."
    },
    "/mocks/{mockId}": {
      "schema": "MockTest",
      "description": "Standard mock tests."
    },
    "/attempts/{attemptId}": {
      "schema": "object",
      "description": "Student exam attempts."
    },
    "/community_channels/{channelId}": {
      "schema": "object",
      "description": "Exam-wise chat channels."
    },
    "/community_messages/{msgId}": {
      "schema": "CommunityMessage",
      "description": "Social learning chat stream."
    },
    "/notes/{noteId}": {
      "schema": "object",
      "description": "Crowdsourced study material."
    }
  }
}
