
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "level": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "missionsCompleted": { "type": "number" },
        "lastActive": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "DailyTarget": {
      "title": "Daily Target",
      "description": "Daily study and practice goals for a student.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questionsGoal": { "type": "number" },
        "questionsCompleted": { "type": "number" },
        "mockGoal": { "type": "number" },
        "mockCompleted": { "type": "number" },
        "studyMinutesGoal": { "type": "number" },
        "studyMinutesCompleted": { "type": "number" },
        "date": { "type": "string" }
      }
    },
    "MistakeEntry": {
      "title": "Mistake Entry",
      "description": "A question incorrectly answered by the student for revision.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questionId": { "type": "string" },
        "questionText": { "type": "string" },
        "correctAnswer": { "type": "string" },
        "userAnswer": { "type": "string" },
        "topic": { "type": "string" },
        "subject": { "type": "string" },
        "savedAt": { "type": "number" }
      }
    },
    "StudySession": {
      "title": "Study Session",
      "description": "A tracked study period using the focus timer.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "type": { "type": "string", "enum": ["pomodoro", "focus"] },
        "createdAt": { "type": "number" }
      }
    },
    "RevisionPlan": {
      "title": "Revision Plan",
      "description": "AI generated revision schedule.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "plan": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles."
    },
    "/dailyTargets/{userId}": {
      "schema": "DailyTarget",
      "description": "Daily goals tracking."
    },
    "/mistakeNotebook/{id}": {
      "schema": "MistakeEntry",
      "description": "Repository of wrong answers for revision."
    },
    "/studySessions/{id}": {
      "schema": "StudySession",
      "description": "Tracked study hours."
    },
    "/revisionPlans/{userId}": {
      "schema": "RevisionPlan",
      "description": "Personalized revision strategies."
    }
  }
}
