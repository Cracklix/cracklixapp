
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account, pass status, and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "activePass": { "type": "string", "enum": ["free", "silver", "gold", "elite"] },
        "passExpiry": { "type": "number" },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "district": { "type": "string" },
        "targetExam": { "type": "string" },
        "referralCode": { "type": "string" },
        "createdAt": { "type": "number" },
        "bookmarks": { "type": "array" }
      }
    },
    "TestSeries": {
      "title": "Test Series",
      "description": "A collection of mocks and materials for a specific exam.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "exam": { "type": "string" },
        "category": { "type": "string" },
        "thumbnail": { "type": "string" },
        "totalTests": { "type": "number" },
        "freeTests": { "type": "number" },
        "passRequired": { "type": "string" },
        "price": { "type": "number" },
        "isActive": { "type": "boolean" }
      }
    },
    "Transaction": {
      "title": "Transaction Record",
      "description": "Logs for prepare pass purchases.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "passType": { "type": "string" },
        "status": { "type": "string" },
        "orderId": { "type": "string" },
        "paymentId": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles and roles."
    },
    "/testSeries/{seriesId}": {
      "schema": "TestSeries",
      "description": "Official preparation test series."
    },
    "/transactions/{txnId}": {
      "schema": "Transaction",
      "description": "Payment records for preparer passes."
    }
  }
}
