
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "district": { "type": "string" },
        "targetExam": { "type": "string" },
        "referralCode": { "type": "string" },
        "createdAt": { "type": "number" },
        "bookmarks": { "type": "array" }
      }
    },
    "IngestionJob": {
      "title": "Ingestion Job",
      "description": "Tracking for a multi-page PDF ingestion session.",
      "type": "object",
      "properties": {
        "fileName": { "type": "string" },
        "status": { "type": "string", "enum": ["processing", "review", "completed", "failed"] },
        "totalPages": { "type": "number" },
        "processedPages": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      }
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "User reported issues and requests.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in-progress", "resolved", "closed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "category": { "type": "string", "enum": ["payment", "mock", "login", "bug", "other"] },
        "screenshotUrl": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles and roles."
    },
    "/ingestion_jobs/{jobId}": {
      "schema": "IngestionJob",
      "description": "Metadata for high-volume ingestion jobs."
    },
    "/support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Global support ticket repository."
    }
  }
}
