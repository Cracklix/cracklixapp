
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "level": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "missionsCompleted": { "type": "number" },
        "lastActive": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User subscription details.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "plan": { "type": "string", "enum": ["Monthly", "Quarterly", "Yearly"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "expired", "cancelled"] },
        "startDate": { "type": "number" },
        "endDate": { "type": "number" },
        "paymentId": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment transaction record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "paymentId": { "type": "string" },
        "orderId": { "type": "string" },
        "plan": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Billing invoice for subscriptions.",
      "type": "object",
      "properties": {
        "invoiceId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "gst": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles and statistics."
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "Active and past user subscriptions."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Transaction logs."
    },
    "/premiumAccess/{userId}": {
      "schema": "object",
      "description": "Quick lookup for premium status."
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "User billing records."
    }
  }
}
