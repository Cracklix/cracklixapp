
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "level": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "missionsCompleted": { "type": "number" },
        "lastActive": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "AdminRecord": {
      "title": "Admin Record",
      "description": "Permissions and status for admin accounts.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "active": { "type": "boolean" },
        "createdAt": { "type": "number" }
      }
    },
    "CMSContent": {
      "title": "CMS Content",
      "description": "Platform-wide articles and announcements.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "number" }
      }
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Chronological log of administrative actions.",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "adminEmail": { "type": "string" },
        "action": { "type": "string" },
        "target": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "FeatureFlag": {
      "title": "Feature Flag",
      "description": "Toggles for system features.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "enabled": { "type": "boolean" },
        "description": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles."
    },
    "/admins/{id}": {
      "schema": "AdminRecord",
      "description": "Administrative account registry."
    },
    "/cms/{id}": {
      "schema": "CMSContent",
      "description": "Content management repository."
    },
    "/auditLogs/{id}": {
      "schema": "AuditLog",
      "description": "Admin activity history."
    },
    "/featureFlags/{id}": {
      "schema": "FeatureFlag",
      "description": "Platform feature controls."
    },
    "/notifications/{id}": {
      "schema": "Notification",
      "description": "User-specific alerts."
    },
    "/liveActivity/{id}": {
      "schema": "LiveActivity",
      "description": "Global activity feed."
    },
    "/currentAffairs/{id}": {
      "schema": "CurrentAffair",
      "description": "Article feed."
    },
    "/mocks/{id}": {
      "schema": "MockTest",
      "description": "Exam simulations."
    },
    "/attempts/{id}": {
      "schema": "Attempt",
      "description": "Historical performance logs."
    },
    "/payments/{id}": {
      "schema": "Payment",
      "description": "Financial records."
    }
  }
}
