
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "level": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "missionsCompleted": { "type": "number" },
        "lastActive": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Real-time alerts for users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "type": { "type": "string", "enum": ["mock", "exam", "achievement", "system"] },
        "createdAt": { "type": "number" }
      }
    },
    "LiveActivity": {
      "title": "Live Activity",
      "description": "Platform-wide activity pulse.",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "CurrentAffair": {
      "title": "Current Affair",
      "description": "Daily news and exam-relevant current affairs.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "language": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "MockTest": {
      "title": "Mock Test",
      "description": "Standardized exam simulations.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "exam": { "type": "string" },
        "duration": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "negativeMarking": { "type": "number" },
        "premium": { "type": "boolean" },
        "published": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles."
    },
    "/notifications/{id}": {
      "schema": "Notification",
      "description": "User-specific alerts."
    },
    "/liveActivity/{id}": {
      "schema": "LiveActivity",
      "description": "Global activity feed."
    },
    "/currentAffairs/{id}": {
      "schema": "CurrentAffair",
      "description": "Article feed."
    },
    "/mocks/{id}": {
      "schema": "MockTest",
      "description": "Exam simulations."
    }
  }
}
