
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "district": { "type": "string" },
        "targetExam": { "type": "string" },
        "referralCode": { "type": "string" },
        "createdAt": { "type": "number" },
        "bookmarks": { "type": "array" }
      }
    },
    "Plan": {
      "title": "Subscription Plan",
      "description": "Defined access tiers for the platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "number", "description": "Days" },
        "features": { "type": "array", "items": { "type": "string" } },
        "exams": { "type": "array", "description": "Specific exams this pass unlocks (empty for all)" },
        "active": { "type": "boolean" },
        "tier": { "type": "string", "enum": ["silver", "gold", "elite"] }
      }
    },
    "Subscription": {
      "title": "User Subscription",
      "description": "Active access record for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "planName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired", "cancelled"] },
        "startDate": { "type": "number" },
        "expiresAt": { "type": "number" },
        "paymentId": { "type": "string" },
        "features": { "type": "array" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles and roles."
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Dynamic pricing tiers and feature manifests."
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "User subscription ledger."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Transaction logs."
    },
    "/questions/{qId}": {
      "schema": "Question",
      "description": "Central bilingual question bank repository."
    }
  }
}
