
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Comprehensive student identity and subscription node.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "activePass": { "type": "string", "enum": ["free", "pass_plus", "premium", "elite"] },
        "passExpiry": { "type": "number" },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "district": { "type": "string" },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      }
    },
    "MockTest": {
      "title": "Simulation Artifact",
      "description": "Standardized competitive exam simulation.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "exam": { "type": "string" },
        "category": { "type": "string", "enum": ["full", "sectional", "subject", "chapter", "pyq"] },
        "duration": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "negativeMarking": { "type": "number" },
        "accessType": { "type": "string", "enum": ["free", "pass_plus", "premium", "elite"] },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "sections": { "type": "array" },
        "createdAt": { "type": "number" }
      }
    },
    "ExamAttempt": {
      "title": "CBT Session Log",
      "description": "Real-time state and result audit for an exam attempt.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mockId": { "type": "string" },
        "status": { "type": "string", "enum": ["ongoing", "paused", "completed"] },
        "answers": { "type": "object" },
        "score": { "type": "number" },
        "accuracy": { "type": "number" },
        "percentile": { "type": "number" },
        "rank": { "type": "number" },
        "timeSpent": { "type": "object" },
        "startedAt": { "type": "number" },
        "completedAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student identity records."
    },
    "/mocks/{mockId}": {
      "schema": "MockTest",
      "description": "Institutional exam definitions."
    },
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Global atomic question bank."
    },
    "/attempts/{attemptId}": {
      "schema": "ExamAttempt",
      "description": "User performance audit trail."
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Subscription tier definitions."
    },
    "/transactions/{txnId}": {
      "schema": "Transaction",
      "description": "Razorpay payment ledger."
    }
  }
}
