
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "JobAlert": {
      "title": "Job Alert",
      "description": "Punjab government vacancy notification.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "department": { "type": "string" },
        "postCount": { "type": "number" },
        "lastDate": { "type": "number" },
        "applyUrl": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "closed"] }
      }
    },
    "Referral": {
      "title": "Referral Record",
      "description": "Tracks successful invites.",
      "type": "object",
      "properties": {
        "referrerId": { "type": "string" },
        "referredId": { "type": "string" },
        "rewardClaimed": { "type": "boolean" },
        "createdAt": { "type": "number" }
      }
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "User help requests.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "resolved"] },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and rankings."
    },
    "/jobAlerts/{alertId}": {
      "schema": "JobAlert",
      "description": "Punjab vacancy updates."
    },
    "/referrals/{id}": {
      "schema": "Referral",
      "description": "Viral loop tracking."
    },
    "/supportTickets/{id}": {
      "schema": "SupportTicket",
      "description": "Customer support logs."
    },
    "/userWallets/{userId}": {
      "schema": "object",
      "description": "Coin balances and transaction logs."
    }
  }
}
