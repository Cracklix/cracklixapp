{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "referralCode": { "type": "string" },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "MockTest": {
      "title": "Mock Test",
      "description": "CBT simulation structure.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "exam": { "type": "string" },
        "duration": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "premium": { "type": "boolean" }
      }
    },
    "DailyTarget": {
      "title": "Daily Target",
      "description": "Student daily goals tracking.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questionsGoal": { "type": "number" },
        "questionsCompleted": { "type": "number" },
        "mockGoal": { "type": "number" },
        "mockCompleted": { "type": "number" },
        "studyMinutesGoal": { "type": "number" },
        "studyMinutesCompleted": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and settings."
    },
    "/mocks/{mockId}": {
      "schema": "MockTest",
      "description": "Test definitions."
    },
    "/dailyTargets/{userId}": {
      "schema": "DailyTarget",
      "description": "Goal tracking per user."
    }
  }
}