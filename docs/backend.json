
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "district": { "type": "string" },
        "targetExam": { "type": "string" },
        "isPro": { "type": "boolean" },
        "referralCode": { "type": "string" },
        "createdAt": { "type": "number" },
        "bookmarks": { "type": "array" }
      }
    },
    "MockTest": {
      "title": "Mock Test",
      "description": "CBT Exam configuration.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "exam": { "type": "string" },
        "duration": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "negativeMarking": { "type": "number" },
        "isLive": { "type": "boolean" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "number" }
      }
    },
    "CommunityMessage": {
      "title": "Community Message",
      "description": "Social learning chat message.",
      "type": "object",
      "properties": {
        "channelId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles and roles."
    },
    "/questions/{qId}": {
      "schema": "object",
      "description": "Bilingual question bank."
    },
    "/mocks/{mockId}": {
      "schema": "MockTest",
      "description": "Standardized mock tests."
    },
    "/community_messages/{msgId}": {
      "schema": "CommunityMessage",
      "description": "Real-time discussion streams."
    },
    "/jobAlerts/{jobId}": {
      "schema": "object",
      "description": "Punjab government vacancy alerts."
    },
    "/leaderboards/{userId}": {
      "schema": "object",
      "description": "Punjab State Merit Registry."
    }
  }
}
