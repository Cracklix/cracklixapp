
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Student account, pass status, and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "activePass": { "type": "string", "enum": ["free", "silver", "gold", "elite"] },
        "passExpiry": { "type": "number" },
        "purchasedTests": { "type": "array" },
        "languageMode": { "type": "string" },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      }
    },
    "Question": {
      "title": "Question",
      "description": "Bilingual academic question artifact.",
      "type": "object",
      "properties": {
        "en": { "type": "object", "properties": { "question": { "type": "string" }, "options": { "type": "array" }, "explanation": { "type": "string" }, "image": { "type": "string" } } },
        "pa": { "type": "object", "properties": { "question": { "type": "string" }, "options": { "type": "array" }, "explanation": { "type": "string" } } },
        "hi": { "type": "object", "properties": { "question": { "type": "string" }, "options": { "type": "array" }, "explanation": { "type": "string" } } },
        "correctAnswer": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "difficulty": { "type": "string" },
        "marks": { "type": "number" },
        "negativeMarks": { "type": "number" },
        "status": { "type": "string" },
        "source": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "MockTest": {
      "title": "Mock Simulation",
      "description": "Standardized computer-based test simulation.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "exam": { "type": "string" },
        "category": { "type": "string" },
        "duration": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "negativeMarking": { "type": "number" },
        "status": { "type": "string" },
        "accessType": { "type": "string" },
        "sections": { "type": "array" },
        "createdAt": { "type": "number" }
      }
    },
    "ExamAttempt": {
      "title": "Exam Attempt",
      "description": "User specific session data for a mock test.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mockId": { "type": "string" },
        "status": { "type": "string" },
        "answers": { "type": "object" },
        "timeSpent": { "type": "object" },
        "score": { "type": "number" },
        "accuracy": { "type": "number" },
        "startedAt": { "type": "number" },
        "completedAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student identity nodes."
    },
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Global atomic question bank."
    },
    "/mocks/{mockId}": {
      "schema": "MockTest",
      "description": "Simulation clusters."
    },
    "/attempts/{attemptId}": {
      "schema": "ExamAttempt",
      "description": "CBT session state logs."
    }
  }
}
