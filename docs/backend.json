
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "district": { "type": "string" },
        "targetExam": { "type": "string" },
        "referralCode": { "type": "string" },
        "createdAt": { "type": "number" },
        "bookmarks": { "type": "array" }
      }
    },
    "IngestionJob": {
      "title": "Ingestion Job",
      "description": "Tracking for a multi-page PDF ingestion session.",
      "type": "object",
      "properties": {
        "fileName": { "type": "string" },
        "status": { "type": "string", "enum": ["processing", "review", "completed", "failed"] },
        "totalPages": { "type": "number" },
        "processedPages": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      }
    },
    "IngestionChunk": {
      "title": "Ingestion Chunk",
      "description": "Extracted data from a single page of an ingestion job.",
      "type": "object",
      "properties": {
        "pageNumber": { "type": "number" },
        "questions": { "type": "array" },
        "diSets": { "type": "array" },
        "confidence": { "type": "number" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles and roles."
    },
    "/ingestion_jobs/{jobId}": {
      "schema": "IngestionJob",
      "description": "Metadata for high-volume ingestion jobs."
    },
    "/ingestion_jobs/{jobId}/chunks/{pageId}": {
      "schema": "IngestionChunk",
      "description": "Temporary storage for extracted chunks."
    },
    "/questions/{qId}": {
      "schema": "Question",
      "description": "Central bilingual question bank repository."
    }
  }
}
