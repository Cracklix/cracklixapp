{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Student account, pass status, and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "activePass": { "type": "string", "enum": ["free", "silver", "gold", "elite"] },
        "passExpiry": { "type": "number" },
        "purchasedTests": { "type": "array" },
        "languageMode": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      }
    },
    "TestSeries": {
      "title": "Test Series",
      "description": "Board-specific simulation clusters.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "thumbnail": { "type": "string" },
        "totalTests": { "type": "number" },
        "freeTests": { "type": "number" },
        "price": { "type": "number" },
        "passRequired": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "Transaction": {
      "title": "Transaction Signal",
      "description": "Audited preparation pass purchases.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "passType": { "type": "string" },
        "status": { "type": "string" },
        "paymentId": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student identity nodes."
    },
    "/testSeries/{seriesId}": {
      "schema": "TestSeries",
      "description": "Recruitment preparation clusters."
    },
    "/mocks/{mockId}": {
      "schema": "MockTest",
      "description": "High-fidelity preparing simulations."
    },
    "/transactions/{txnId}": {
      "schema": "Transaction",
      "description": "Preparatory acquisition ledger."
    }
  }
}