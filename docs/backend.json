
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "district": { "type": "string" },
        "targetExam": { "type": "string" },
        "isPro": { "type": "boolean" },
        "referralCode": { "type": "string" },
        "createdAt": { "type": "number" },
        "bookmarks": { "type": "array" }
      }
    },
    "Plan": {
      "title": "Subscription Plan",
      "description": "Defined access tiers for the platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "number", "description": "Days" },
        "features": { "type": "array" },
        "exams": { "type": "array", "description": "Specific exams this pass unlocks" },
        "active": { "type": "boolean" }
      }
    },
    "Subscription": {
      "title": "User Subscription",
      "description": "Active access record for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired", "cancelled"] },
        "expiresAt": { "type": "number" },
        "paymentId": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Question": {
      "title": "Question Bank Item",
      "description": "Atomic bilingual question for the central bank.",
      "type": "object",
      "properties": {
        "question_en": { "type": "string" },
        "question_pa": { "type": "string" },
        "options_en": { "type": "array" },
        "options_pa": { "type": "array" },
        "correctAnswer": { "type": "string" },
        "explanation_en": { "type": "string" },
        "explanation_pa": { "type": "string" },
        "subject": { 
          "type": "string", 
          "enum": ["Punjab GK", "Quant", "Reasoning", "English", "Punjabi", "Computer", "Current Affairs", "General Science", "History", "Polity", "Geography", "Agriculture", "Static GK", "Law/Constitution", "Environment"] 
        },
        "topic": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "exam": { "type": "string" },
        "pyq": { "type": "boolean" },
        "year": { "type": "number" },
        "source": { "type": "string" },
        "qualityScore": { "type": "number" },
        "usageCount": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "createdAt": { "type": "number" },
        "aiGenerated": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles and roles."
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Dynamic pricing tiers."
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "User subscription ledger."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Transaction logs."
    },
    "/questions/{qId}": {
      "schema": "Question",
      "description": "Central bilingual question bank repository."
    }
  }
}
