{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "referralCode": { "type": "string" },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "ExamMaster": {
      "title": "Master Exam Definition",
      "description": "Comprehensive details for a specific Punjab government exam.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "department": { "type": "string" },
        "languages": { "type": "array", "items": { "type": "string" } },
        "negativeMarking": { "type": "number" },
        "duration": { "type": "number" },
        "totalMarks": { "type": "number" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "eligibility": { "type": "string" },
        "salary": { "type": "string" },
        "icon": { "type": "string" }
      }
    },
    "Syllabus": {
      "title": "Exam Syllabus",
      "description": "Mapping of topics to subjects for a specific exam.",
      "type": "object",
      "properties": {
        "examId": { "type": "string" },
        "subject": { "type": "string" },
        "topics": { "type": "array", "items": { "type": "string" } },
        "weightage": { "type": "number" }
      }
    },
    "PYQ": {
      "title": "Previous Year Question",
      "description": "Authentic questions from previous Punjab govt exams.",
      "type": "object",
      "properties": {
        "exam": { "type": "string" },
        "year": { "type": "number" },
        "question_en": { "type": "string" },
        "question_pa": { "type": "string" },
        "options_en": { "type": "array", "items": { "type": "string" } },
        "options_pa": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "number" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "explanation": { "type": "string" }
      }
    },
    "DailyTarget": {
      "title": "Daily Target",
      "description": "Student daily goals tracking.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questionsGoal": { "type": "number" },
        "questionsCompleted": { "type": "number" },
        "mockGoal": { "type": "number" },
        "mockCompleted": { "type": "number" },
        "studyMinutesGoal": { "type": "number" },
        "studyMinutesCompleted": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and settings."
    },
    "/exams/{examId}": {
      "schema": "ExamMaster",
      "description": "Master list of Punjab Government exams."
    },
    "/syllabus/{syllabusId}": {
      "schema": "Syllabus",
      "description": "Subject-wise syllabus breakdown."
    },
    "/pyqs/{pyqId}": {
      "schema": "PYQ",
      "description": "Previous year questions bank."
    },
    "/dailyTargets/{userId}": {
      "schema": "DailyTarget",
      "description": "Goal tracking per user."
    },
    "/jobAlerts/{jobId}": {
      "schema": "object",
      "description": "Punjab government vacancy updates."
    },
    "/currentAffairs/{articleId}": {
      "schema": "object",
      "description": "Daily news and study notes."
    },
    "/liveRanks/{userId}": {
      "schema": "object",
      "description": "Real-time arena leaderboard."
    }
  }
}