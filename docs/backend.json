
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "level": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "missionsCompleted": { "type": "number" },
        "lastActive": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Product": {
      "title": "Marketplace Product",
      "description": "A study resource for sale (PDF, Notes, etc.)",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "thumbnail": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "downloads": { "type": "number" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "createdAt": { "type": "number" }
      }
    },
    "Order": {
      "title": "Marketplace Order",
      "description": "Record of a product purchase.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "productTitle": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "failed"] },
        "paymentId": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "CreatorEarning": {
      "title": "Creator Earning Record",
      "description": "Revenue tracking for creators.",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string" },
        "totalRevenue": { "type": "number" },
        "withdrawn": { "type": "number" },
        "pendingBalance": { "type": "number" },
        "salesCount": { "type": "number" }
      }
    },
    "DailyTarget": {
      "title": "Daily Target",
      "description": "Daily study and practice goals for a student.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questionsGoal": { "type": "number" },
        "questionsCompleted": { "type": "number" },
        "mockGoal": { "type": "number" },
        "mockCompleted": { "type": "number" },
        "studyMinutesGoal": { "type": "number" },
        "studyMinutesCompleted": { "type": "number" },
        "date": { "type": "string" }
      }
    },
    "MistakeEntry": {
      "title": "Mistake Entry",
      "description": "A question incorrectly answered by the student for revision.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questionId": { "type": "string" },
        "questionText": { "type": "string" },
        "correctAnswer": { "type": "string" },
        "userAnswer": { "type": "string" },
        "topic": { "type": "string" },
        "subject": { "type": "string" },
        "savedAt": { "type": "number" }
      }
    },
    "StudySession": {
      "title": "Study Session",
      "description": "A tracked study period using the focus timer.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "type": { "type": "string", "enum": ["pomodoro", "focus"] },
        "createdAt": { "type": "number" }
      }
    },
    "RevisionPlan": {
      "title": "Revision Plan",
      "description": "AI generated revision schedule.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "plan": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "LiveTest": {
      "title": "Live Test",
      "description": "A high-stakes scheduled test competition.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "exam": { "type": "string" },
        "startTime": { "type": "number" },
        "endTime": { "type": "number" },
        "duration": { "type": "number" },
        "questions": { "type": "number" },
        "participants": { "type": "number" },
        "live": { "type": "boolean" }
      }
    },
    "LiveRank": {
      "title": "Live Rank",
      "description": "Real-time ranking entry for a live competition.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "score": { "type": "number" },
        "accuracy": { "type": "number" },
        "lastUpdated": { "type": "number" }
      }
    },
    "BattleRoom": {
      "title": "Battle Room",
      "description": "A 1v1 quiz battle room.",
      "type": "object",
      "properties": {
        "player1": { "type": "string" },
        "player2": { "type": "string" },
        "topic": { "type": "string" },
        "winner": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "live", "finished"] }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Study materials for sale."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Purchase records."
    },
    "/creatorEarnings/{userId}": {
      "schema": "CreatorEarning",
      "description": "Earnings tracking."
    },
    "/dailyTargets/{userId}": {
      "schema": "DailyTarget",
      "description": "Daily goals tracking."
    },
    "/mistakeNotebook/{id}": {
      "schema": "MistakeEntry",
      "description": "Repository of wrong answers for revision."
    },
    "/studySessions/{id}": {
      "schema": "StudySession",
      "description": "Tracked study hours."
    },
    "/revisionPlans/{userId}": {
      "schema": "RevisionPlan",
      "description": "Personalized revision strategies."
    },
    "/liveTests/{id}": {
      "schema": "LiveTest",
      "description": "Scheduled competitions."
    },
    "/liveRanks/{id}": {
      "schema": "LiveRank",
      "description": "Real-time competition rankings."
    },
    "/battleRooms/{id}": {
      "schema": "BattleRoom",
      "description": "1v1 competition rooms."
    }
  }
}
