{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "level": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "missionsCompleted": { "type": "number" },
        "lastActive": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "CurrentAffair": {
      "title": "Current Affair",
      "description": "Daily news and exam-relevant current affairs.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "language": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "PDFResource": {
      "title": "PDF Resource",
      "description": "Study materials and notes in PDF format.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "DailyQuiz": {
      "title": "Daily Quiz",
      "description": "Quick daily assessment questions.",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "string" },
        "topic": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "User-saved items for later review.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["currentAffair", "pdf", "question"] },
        "itemId": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles and statistics."
    },
    "/currentAffairs/{id}": {
      "schema": "CurrentAffair",
      "description": "Article feed."
    },
    "/pdfs/{id}": {
      "schema": "PDFResource",
      "description": "Study documents."
    },
    "/dailyQuizzes/{id}": {
      "schema": "DailyQuiz",
      "description": "Daily mini-assessments."
    },
    "/bookmarks/{id}": {
      "schema": "Bookmark",
      "description": "User saved items."
    }
  }
}