
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "district": { "type": "string" },
        "targetExam": { "type": "string" },
        "isPro": { "type": "boolean" },
        "referralCode": { "type": "string" },
        "createdAt": { "type": "number" },
        "bookmarks": { "type": "array" }
      }
    },
    "MockTest": {
      "title": "Mock Test",
      "description": "CBT Exam configuration.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "exam": { "type": "string" },
        "duration": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "negativeMarking": { "type": "number" },
        "isLive": { "type": "boolean" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "number" }
      }
    },
    "CommunityMessage": {
      "title": "Community Message",
      "description": "Social learning chat message.",
      "type": "object",
      "properties": {
        "channelId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "JobAlert": {
      "title": "Job Alert",
      "description": "Punjab recruitment notification.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "department": { "type": "string" },
        "postCount": { "type": "number" },
        "lastDate": { "type": "number" },
        "applyUrl": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles and roles."
    },
    "/questions/{qId}": {
      "schema": "object",
      "description": "Bilingual question bank."
    },
    "/mocks/{mockId}": {
      "schema": "MockTest",
      "description": "Standardized mock tests."
    },
    "/attempts/{attemptId}": {
      "schema": "object",
      "description": "User test attempts and analytics."
    },
    "/community_messages/{msgId}": {
      "schema": "CommunityMessage",
      "description": "Real-time discussion streams."
    },
    "/jobAlerts/{jobId}": {
      "schema": "JobAlert",
      "description": "Punjab government vacancy alerts."
    },
    "/leaderboards/{userId}": {
      "schema": "object",
      "description": "Punjab State Merit Registry."
    },
    "/subscriptions/{subId}": {
      "schema": "object",
      "description": "Premium PASS records."
    },
    "/ai_logs/{logId}": {
      "schema": "object",
      "description": "Gemini token usage tracking."
    },
    "/typing_tests/{id}": {
      "schema": "object",
      "description": "Student typing speed logs."
    },
    "/reports/{reportId}": {
      "schema": "object",
      "description": "Community moderation reports."
    }
  }
}
