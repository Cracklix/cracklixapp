
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "level": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "missionsCompleted": { "type": "number" },
        "lastActive": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "Snapshots for rankings.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "exam": { "type": "string" },
        "district": { "type": "string" },
        "xp": { "type": "number" },
        "accuracy": { "type": "number" },
        "streak": { "type": "number" },
        "updatedAt": { "type": "number" }
      }
    },
    "MockAnalytics": {
      "title": "Mock Analytics",
      "description": "Detailed breakdown of a mock test attempt.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mockId": { "type": "string" },
        "correct": { "type": "number" },
        "wrong": { "type": "number" },
        "accuracy": { "type": "number" },
        "weakTopics": { "type": "array", "items": { "type": "string" } },
        "readiness": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles and statistics."
    },
    "/leaderboards/{entryId}": {
      "schema": "LeaderboardEntry",
      "description": "Aggregated ranking data."
    },
    "/analytics/{analyticsId}": {
      "schema": "MockAnalytics",
      "description": "Historical performance data per attempt."
    },
    "/streaks/{userId}": {
      "schema": "object",
      "description": "User login and activity streaks."
    }
  }
}
