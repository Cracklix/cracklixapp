
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "coins": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "state": { "type": "string", "description": "User's target state for exams." },
        "targetExam": { "type": "string", "description": "Primary exam category (SSC, UPSC, etc.)" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "JobAlert": {
      "title": "Job Alert",
      "description": "National and State government vacancy notification.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "department": { "type": "string" },
        "postCount": { "type": "number" },
        "lastDate": { "type": "number" },
        "applyUrl": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string", "description": "State or Central" },
        "status": { "type": "string", "enum": ["active", "closed"] }
      }
    },
    "Referral": {
      "title": "Referral Record",
      "description": "Tracks successful invites and commissions.",
      "type": "object",
      "properties": {
        "referrerId": { "type": "string" },
        "referredId": { "type": "string" },
        "rewardClaimed": { "type": "boolean" },
        "createdAt": { "type": "number" }
      }
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "User help requests.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "resolved"] },
        "createdAt": { "type": "number" }
      }
    },
    "RankPrediction": {
      "title": "AI Rank Prediction",
      "description": "AI-generated prediction of student success.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "exam": { "type": "string" },
        "probability": { "type": "number" },
        "predictedRank": { "type": "string" },
        "weakAreas": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Global user profiles."
    },
    "/jobAlerts/{alertId}": {
      "schema": "JobAlert",
      "description": "National vacancy updates."
    },
    "/referrals/{id}": {
      "schema": "Referral",
      "description": "Viral loop tracking."
    },
    "/supportTickets/{id}": {
      "schema": "SupportTicket",
      "description": "Customer support logs."
    },
    "/rankPredictions/{userId}": {
      "schema": "RankPrediction",
      "description": "AI Rank Insight data."
    },
    "/systemMetrics/global": {
      "schema": "object",
      "description": "SaaS level platform metrics."
    }
  }
}
