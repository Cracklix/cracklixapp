
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account and performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin", "superadmin", "creator"] },
        "xp": { "type": "number" },
        "streak": { "type": "number" },
        "level": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "LiveClass": {
      "title": "Live Class",
      "description": "Virtual classroom session data.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "teacherName": { "type": "string" },
        "exam": { "type": "string" },
        "live": { "type": "boolean" },
        "scheduledAt": { "type": "number" }
      }
    },
    "Product": {
      "title": "Marketplace Product",
      "description": "Study resource for sale.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "number" },
        "creatorId": { "type": "string" },
        "downloads": { "type": "number" }
      }
    },
    "DailyTarget": {
      "title": "Daily Target",
      "description": "Daily student goals tracking.",
      "type": "object",
      "properties": {
        "questionsGoal": { "type": "number" },
        "questionsCompleted": { "type": "number" },
        "studyMinutesGoal": { "type": "number" },
        "studyMinutesCompleted": { "type": "number" }
      }
    },
    "AiChat": {
      "title": "AI Chat History",
      "description": "Interaction log with AI Tutor.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "response": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and rankings."
    },
    "/liveClasses/{classId}": {
      "schema": "LiveClass",
      "description": "Live teaching sessions."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Marketplace study materials."
    },
    "/dailyTargets/{userId}": {
      "schema": "DailyTarget",
      "description": "Realtime goal tracking."
    },
    "/aiChats/{chatId}": {
      "schema": "AiChat",
      "description": "Doubt solving history."
    },
    "/classChats/{id}": {
      "schema": "object",
      "description": "Realtime classroom discussion logs."
    },
    "/liveRanks/{id}": {
      "schema": "object",
      "description": "Realtime arena rankings for live tests."
    }
  }
}
