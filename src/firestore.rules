rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Master Access Helper
    function isMaster() {
      return request.auth != null && (
        request.auth.token.email == 'arshdeepgrewal1122@gmail.com' || 
        request.auth.token.email == 'deepgrewal2600@gmail.com'
      );
    }

    // Role-based Access Helper
    function isAdmin() {
      return isMaster() || (
        request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin']
      );
    }

    // Authenticated User Helper
    function isAuthenticated() {
      return request.auth != null;
    }

    // Default: Master Admin has full read/write across ALL collections
    match /{document=**} {
      allow read, write: if isMaster();
    }

    // USER PROFILES
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if (request.auth.uid == userId) || isAdmin();
    }

    // COMMUNITY MESSAGES
    match /communityMessages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.senderId == request.auth.uid);
    }

    // MOCKS & SOVEREIGN QUESTIONS
    match /mocks/{mockId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /questions/{questionId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // ATTEMPTS & ANSWERS
    match /attempts/{attemptId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());

      match /answers/{answerId} {
        allow read, write: if isAuthenticated() && (get(/databases/$(database)/documents/attempts/$(attemptId)).data.userId == request.auth.uid || isAdmin());
      }
    }

    // GLOBAL BANK
    match /questions/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // PASSES & SUBSCRIPTIONS
    match /plans/{id} { allow read: if true; allow write: if isAdmin(); }
    match /premiumAccess/{userId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /subscriptions/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
  }
}