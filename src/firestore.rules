rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Master Access Helper
    function isMaster() {
      return request.auth != null && (
        request.auth.token.email == 'arshdeepgrewal1122@gmail.com' || 
        request.auth.token.email == 'deepgrewal2600@gmail.com'
      );
    }

    // Role-based Access Helper
    function isAdmin() {
      return isMaster() || (
        request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin']
      );
    }

    // Authenticated User Helper
    function isAuthenticated() {
      return request.auth != null;
    }

    // Default: Master Admin has full read/write across ALL collections
    match /{document=**} {
      allow read, write: if isMaster();
    }

    // USER PROFILES
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if (request.auth.uid == userId) || isAdmin();
    }

    // COMMUNITY MESSAGES (New optimized structure)
    match /communityMessages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.senderId == request.auth.uid);
    }
    
    match /communityRooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ACADEMIC DATA
    match /questions/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /mocks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /pyqs/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // SUBSCRIPTIONS & MARKETPLACE
    match /plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin() || (isAuthenticated() && request.resource.data.creatorId == request.auth.uid);
    }
    match /orders/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // LEADERBOARD & ATTEMPTS
    match /leaderboards/{userId} {
      allow read: if isAuthenticated();
      allow write: if (request.auth.uid == userId) || isAdmin();
    }
    match /attempts/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // OPERATIONAL SIGNALS
    match /jobAlerts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /notifications/{id} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || resource.data.userId == "all");
      allow write: if isAdmin();
    }
    match /support_tickets/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /dailyTargets/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
  }
}