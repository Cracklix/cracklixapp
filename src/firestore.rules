
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic Auth Helpers
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    
    // Master Admin Logic
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'arshdeepgrewal1122@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'])
      );
    }

    // SYSTEM FALLBACK: Hardcoded email has master read/write
    match /{document=**} {
      allow read, write: if isAuthenticated() && request.auth.token.email == 'arshdeepgrewal1122@gmail.com';
    }

    // USER PROFILES
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // ACADEMIC ASSETS (Questions, Mocks)
    match /questions/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /question_drafts/{id} {
      allow read, write: if isAdmin();
    }
    match /mocks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      match /questions/{qId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // COMMUNITY & SOCIAL
    match /community_messages/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.senderId == request.auth.uid;
    }

    // OPERATIONAL
    match /jobAlerts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /notifications/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /cms/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /aiUsage/{id} {
      allow read: if isAuthenticated() && (id.startsWith(request.auth.uid) || isAdmin());
      allow write: if isAuthenticated() && (id.startsWith(request.auth.uid) || isAdmin());
    }
  }
}
