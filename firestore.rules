
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Auth Helpers
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin');
    }

    // Production Rule Mapping
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
    match /questions/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /mocks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      match /questions/{qId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }
    match /attempts/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    match /community_channels/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /community_messages/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAdmin() || resource.data.senderId == request.auth.uid;
    }
    match /notes/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow write: if isAdmin() || resource.data.uploadedBy == request.auth.uid;
    }
    match /liveRanks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /liveActivity/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /notifications/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    
    // Default Security
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
