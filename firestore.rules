
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Master Access Helper
    function isMaster() {
      return request.auth != null && request.auth.token.email == 'arshdeepgrewal1122@gmail.com';
    }

    // Role-based Access Helper
    function isAdmin() {
      return isMaster() || (
        request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin']
      );
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    match /{document=**} {
      allow read, write: if isMaster();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if (request.auth.uid == userId) || isAdmin();
    }

    match /questions/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /ingestion_jobs/{id} {
      allow read, write: if isAdmin();
      match /chunks/{chunkId} {
        allow read, write: if isAdmin();
      }
    }

    match /community_messages/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAdmin() || resource.data.senderId == request.auth.uid;
    }
    
    match /aiChats/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /leaderboards/{userId} {
      allow read: if isAuthenticated();
      allow write: if (request.auth.uid == userId) || isAdmin();
    }

    match /attempts/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /jobAlerts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /notifications/{id} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow write: if isAdmin();
    }
  }
}
