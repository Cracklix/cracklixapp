
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin');
    }

    // User Profiles & Operational Docs
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
    match /dailyTargets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
    match /readiness/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
    match /aiUsage/{id} {
      allow read: if isAuthenticated() && (id.split('_')[0] == request.auth.uid || isAdmin());
      allow write: if isAuthenticated() && (id.split('_')[0] == request.auth.uid || isAdmin());
    }

    // Global Academic Assets
    match /mocks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      match /questions/{qId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }
    match /questions/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /pyqs/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /currentAffairs/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /jobAlerts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Competitive System
    match /leaderboards/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
    match /liveRanks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /liveActivity/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /attempts/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Support & Comms
    match /notifications/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
    }
    match /supportTickets/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
    }
    
    // Default fallback
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
