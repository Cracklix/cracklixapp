rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin');
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Daily Targets & Analytics
    match /dailyTargets/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /readiness/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /analytics/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /attempts/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Academic Infrastructure
    match /exams/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /syllabus/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /pyqs/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /mocks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      match /questions/{qId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }
    match /currentAffairs/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /jobAlerts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // AI & Tutoring
    match /aiChats/{id} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    match /aiUsage/{id} {
      allow read: if isAuthenticated() && id.startsWith(request.auth.uid);
      allow write: if isAuthenticated() && id.startsWith(request.auth.uid);
    }

    // Marketplace
    match /products/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.creatorId == request.auth.uid || isAdmin());
    }
    match /orders/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
    }
    match /creatorEarnings/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Live & Real-time
    match /liveActivity/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /liveRanks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /liveClasses/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /classChats/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    match /attendance/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Daily Quizzes
    match /dailyQuizzes/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Support
    match /supportTickets/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
    }

    // Mistake Notebook
    match /mistakeNotebook/{id} {
      allow read, write: if isAuthenticated() && (resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }

    // Wallet
    match /userWallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
      
      match /transactions/{id} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }
    }

    // CMS
    match /cms/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // AI Generated Mocks
    match /aiGeneratedMocks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /questions/{qId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // Premium Access
    match /premiumAccess/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Subscriptions & Payments
    match /subscriptions/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    match /payments/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Admin Registry
    match /admins/{id} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}