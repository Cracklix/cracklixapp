rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin');
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Daily Targets & Analytics
    match /dailyTargets/{userId} {
      allow read, write: if isOwner(userId);
    }
    match /analytics/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    match /attempts/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // AI & Tutoring
    match /aiChats/{id} {
      allow read, write: if isAuthenticated() && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
    match /aiUsage/{id} {
      allow read, write: if isAuthenticated(); // Controlled by document ID structure {userId}_{date}
    }

    // Content: Mocks, Questions, Exams (Admin only write)
    match /mocks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      match /questions/{qId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }
    match /questions/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /exams/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /currentAffairs/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Marketplace
    match /products/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Creators can upload
      allow update, delete: if isAuthenticated() && (resource.data.creatorId == request.auth.uid || isAdmin());
    }
    match /orders/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
    }
    match /creatorEarnings/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // Social & Live Features
    match /leaderboards/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
    }
    match /liveRanks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    match /liveActivity/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }
    match /referrals/{id} {
      allow read, write: if isAuthenticated();
    }

    // Support & Feedback
    match /supportTickets/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
    }

    // Live Classes
    match /liveClasses/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /classChats/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }
    match /attendance/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // System
    match /premiumAccess/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
    match /admins/{id} {
      allow read, write: if isAdmin();
    }
    match /cms/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /pdfs/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}