
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic Auth Helpers
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'arshdeepgrewal1122@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'))
      );
    }

    // USER PROFILES
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // ACADEMIC ASSETS (Questions, Mocks)
    match /questions/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /mocks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      match /questions/{qId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }
    match /pyqs/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // COMMUNITY & SOCIAL
    match /community_messages/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.senderId == request.auth.uid;
    }
    match /aiChats/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // LEADERBOARD & ANALYTICS
    match /leaderboards/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
    match /liveRanks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /liveActivity/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // OPERATIONAL (Jobs, Notifications, CMS)
    match /jobAlerts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /notifications/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /cms/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /premiumAccess/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Default Fallback
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
